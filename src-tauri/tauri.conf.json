{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Localization-UI",
  "version": "0.1.1",
  "identifier": "com.picoshot.localization-ui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Localization Editor",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "minimizable": true,
        "dragDropEnabled": false,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1MENGQTQxNUUxMUU0QUIKUldTcjVCRmVRZm9NNVRDQURuckczd3RjV0xmT3pUVEVXS3RxK0ozVENGd3pMeS9aeWJuUUlzeTQK",
      "endpoints": [
        "https://github.com/PicoShot/Localization-UI/releases/latest/download/latest.json"
      ]
    }
  }
}
